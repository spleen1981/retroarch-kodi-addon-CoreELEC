#!/bin/sh
# AppImage entry point — runtime for @ADDON_NAME@.
#
# All execution happens within a single FUSE squashfs mount (this one).
# cec-mini-kb and xbox360-controllers-shutdown are started/stopped here
# so they share the mount instead of creating separate FUSE instances
# (multiple concurrent squashfuse processes deadlock on CoreELEC).
#
# Environment variables set by the Python orchestrator:
#   RA_CEC=1              start cec-mini-kb (no poweroff handler)
#   RA_CEC_POWEROFF=1     start cec-mini-kb with CEC standby → shutdown
#   RA_XBOX360_SHUTDOWN=1 run xbox360-controllers-shutdown after retroarch exits
#   RA_SHUTDOWN_FLAG=...  path of the flag RetroArch writes when the user picks
#                         "shutdown" from its menu; presence means a poweroff is
#                         pending, so we tell cec-mini-kb to turn the TV off too.
#
# Library loading:
#   lib/       Userspace shared libs bundled from the Lakka build.
#   lib-gpu/   libgbm — needed on framebuffer-only platforms where the system
#              has no libgbm. Skipped on DRM platforms (/dev/dri/card0 present)
#              so the system Mali libgbm (kernel-matched) takes precedence.

APPDIR="$(dirname "$(readlink -f "$0")")"
export APPDIR

_appimage_lib_path() {
    if [ ! -e /dev/dri/card0 ]; then
        echo "$APPDIR/lib:$APPDIR/lib-gpu"
    else
        echo "$APPDIR/lib"
    fi
}

# compat dir: host libcec symlink so cec-mini-kb uses the platform-specific
# CEC adapter (e.g. Amlogic AOCEC) instead of the Lakka-built version.
_compat="/tmp/.appimage_syslibs_@ADDON_NAME@"
mkdir -p "$_compat"
_sys_libcec=$(find /usr/lib /lib -name "libcec.so.*" 2>/dev/null \
    | grep -E "libcec\.so\.[0-9]" | sort -V | tail -1)
if [ -n "$_sys_libcec" ]; then
    ln -sf "$_sys_libcec" "$_compat/@LIBCEC_SONAME@" 2>/dev/null || true
fi

# LD_LIBRARY_PATH for CEC tools: host libcec first, then AppImage libs.
_tool_lib="$_compat:/usr/lib:/lib:$(_appimage_lib_path)"

# LD_LIBRARY_PATH for retroarch: AppImage libs first.
export LD_LIBRARY_PATH="$(_appimage_lib_path)${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export PATH="$APPDIR/bin${PATH:+:$PATH}"

# Start cec-mini-kb in background if requested.
# The --poweroff command runs only on a CEC standby event (TV power button),
# not on SIGTERM — SIGTERM causes a clean exit without triggering poweroff.
_cec_pid=""
if [ "${RA_CEC_POWEROFF:-0}" = "1" ]; then
    _poweroff="shutdown -P now"
    if [ "${RA_XBOX360_SHUTDOWN:-0}" = "1" ]; then
        # xbox360-controllers-shutdown runs from this same squashfs mount.
        # LD_LIBRARY_PATH is inherited from cec-mini-kb's environment.
        # No quoting needed: the path never contains spaces on CoreELEC.
        _poweroff="$APPDIR/bin/xbox360-controllers-shutdown;$_poweroff"
    fi
    LD_LIBRARY_PATH="$_tool_lib" \
        "$APPDIR/bin/cec-mini-kb" --poweroff "$_poweroff" &
    _cec_pid=$!
elif [ "${RA_CEC:-0}" = "1" ]; then
    LD_LIBRARY_PATH="$_tool_lib" "$APPDIR/bin/cec-mini-kb" &
    _cec_pid=$!
fi

# Run retroarch (not via exec so this shell stays alive for cleanup).
"$APPDIR/bin/retroarch" "$@"
_rc=$?

# Stop cec-mini-kb. SIGTERM is sufficient: it causes a clean exit without
# triggering the --poweroff handler (which fires only on CEC standby events).
if [ -n "$_cec_pid" ]; then
    # If the user chose "shutdown" inside RetroArch (flag file present) and the
    # CEC poweroff feature is enabled, tell cec-mini-kb to turn the TV off via
    # SIGUSR1 before we stop it. cec-mini-kb must still be alive for the signal
    # to reach it, so this happens before the kill below. Gated on the shutdown
    # flag (not reboot) so a reboot does not switch the TV off. Give libcec a
    # moment to transmit the CEC standby command to the TV before terminating.
    if [ "${RA_CEC_POWEROFF:-0}" = "1" ] && [ -f "$RA_SHUTDOWN_FLAG" ]; then
        kill -s SIGUSR1 "$_cec_pid" 2>/dev/null
        sleep 1
    else
        kill "$_cec_pid" 2>/dev/null
    fi
    wait "$_cec_pid" 2>/dev/null
fi

# Xbox360 controller shutdown on retroarch exit.
# Always runs when enabled regardless of RA_CEC_POWEROFF: if the CEC power
# button was pressed, xbox360-shutdown already ran inside the --poweroff
# command, but running it again during system shutdown is harmless.
if [ "${RA_XBOX360_SHUTDOWN:-0}" = "1" ]; then
    LD_LIBRARY_PATH="$_tool_lib" "$APPDIR/bin/xbox360-controllers-shutdown"
fi

exit $_rc
