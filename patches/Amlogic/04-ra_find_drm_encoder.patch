+diff --git a/gfx/common/drm_common.c b/gfx/common/drm_common.c
+index 10fb38835f..1c85bda97a 100644
+--- a/gfx/common/drm_common.c
++++ b/gfx/common/drm_common.c
+@@ -142,18 +142,42 @@ bool drm_get_encoder(int fd)
+ {
+    unsigned i;
+ 
+-   for (i = 0; (int)i < g_drm_resources->count_encoders; i++)
++   if (g_drm_connector->encoder_id)
+    {
+-      g_drm_encoder = drmModeGetEncoder(fd, g_drm_resources->encoders[i]);
++      for (i = 0; (int)i < g_drm_resources->count_encoders; i++)
++      {
++         g_drm_encoder = drmModeGetEncoder(fd, g_drm_resources->encoders[i]);
+ 
+-      if (!g_drm_encoder)
+-         continue;
++         if (!g_drm_encoder)
++            continue;
+ 
+-      if (g_drm_encoder->encoder_id == g_drm_connector->encoder_id)
