++         drmModeFreeEncoder(g_drm_encoder);
++         g_drm_encoder = NULL;
++      }
++   }
++
++   /* Some Amlogic/CoreELEC boot paths expose a connected HDMI connector
++    * with connector.encoder_id == 0 while connector.encoders[] contains
++    * valid possible encoders. Fall back to the connector's possible encoder
++    * list instead of failing immediately.
++    */
++   if (!g_drm_encoder)
++   {
++      for (i = 0; (int)i < g_drm_connector->count_encoders; i++)
++      {
++         g_drm_encoder = drmModeGetEncoder(fd, g_drm_connector->encoders[i]);
++
++         if (!g_drm_encoder)
++            continue;
++
++         RARCH_LOG("[DRM] Using possible encoder %u for connector %u.\n",
++               g_drm_encoder->encoder_id,
++               g_drm_connector->connector_id);
++         break;
++      }
+    }
+ 
+    if (!g_drm_encoder)
+@@ -175,13 +199,43 @@ bool drm_get_encoder(int fd)
+    return true;
+ }
+ 
++static uint32_t drm_pick_crtc_for_encoder(void)
++{
++   unsigned i;
++
++   if (!g_drm_encoder || !g_drm_resources)
++      return 0;
++
++   if (g_drm_encoder->crtc_id)
++      return g_drm_encoder->crtc_id;
++
++   for (i = 0; (int)i < g_drm_resources->count_crtcs; i++)
++   {
++      if (g_drm_encoder->possible_crtcs & (1u << i))
