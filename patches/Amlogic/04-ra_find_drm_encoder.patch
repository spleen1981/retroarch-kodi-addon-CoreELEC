++         RARCH_LOG("[DRM] Encoder %u has no active CRTC, using possible CRTC %u.\n",
++               g_drm_encoder->encoder_id,
++               g_drm_resources->crtcs[i]);
++         return g_drm_resources->crtcs[i];
++      }
++   }
++
++   return 0;
++}
++
+ void drm_setup(int fd)
+ {
+-   g_crtc_id        = g_drm_encoder->crtc_id;
++   g_crtc_id        = drm_pick_crtc_for_encoder();
+    g_connector_id   = g_drm_connector->connector_id;
+-   g_orig_crtc      = drmModeGetCrtc(fd, g_crtc_id);
+-   if (!g_orig_crtc)
+-      RARCH_WARN("[DRM] Cannot find original CRTC.\n");
++
++   if (!g_crtc_id)
++      RARCH_WARN("[DRM] Cannot find suitable CRTC.\n");
++   else
++   {
++      g_orig_crtc   = drmModeGetCrtc(fd, g_crtc_id);
++      if (!g_orig_crtc)
